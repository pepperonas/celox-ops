# Database
POSTGRES_USER=celoxops
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=celoxops
DATABASE_URL=postgresql+asyncpg://celoxops:CHANGE_ME@db:5432/celoxops

# Auth
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Business (used in invoice PDFs)
BUSINESS_NAME=Your Company Name
BUSINESS_OWNER=Your Name
BUSINESS_ADDRESS=Street, ZIP City
BUSINESS_EMAIL=info@example.com
BUSINESS_WEB=https://example.com
BUSINESS_TAX_ID=
BUSINESS_TAX_NUMBER=
BUSINESS_BANK_NAME=
BUSINESS_BANK_IBAN=
BUSINESS_BANK_BIC=
BUSINESS_PAYPAL=
KLEINUNTERNEHMER=true

# App
APP_URL=https://your-domain.com
PDF_STORAGE_PATH=/data/invoices
LOGO_PATH=/data/assets/logo.png
SIGNATURE_PATH=/data/assets/signature.png

# Token Tracker Integration (optional)
# Get the admin key from your Token Tracker instance: Settings > Share API
TOKEN_TRACKER_BASE_URL=
TOKEN_TRACKER_ADMIN_KEY=
